---
import Base from '../layouts/Base.astro';
import { withBase } from '../lib/url.js';
---
<Base title="Page not found">
  <section class="hero">
    <div class="container">
      <p class="eyebrow">404</p>
      <h1>This page doesn't exist</h1>
      <p class="lead" style="margin-top:20px;">The link may be old or mistyped. Head back to the homepage.</p>
      <a class="btn" href={withBase('/')} style="margin-top:30px;">Go to homepage</a>
    </div>
  </section>
</Base>
