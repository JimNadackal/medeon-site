---
import Base from '../layouts/Base.astro';
import page from '../../content/team-page.json';
import { withBase } from '../lib/url.js';

const modules = import.meta.glob('../../content/team/*.md', { eager: true });
const members = Object.values(modules)
  .map((m) => ({ ...m.frontmatter, Content: m.Content }))
  .sort((a, b) => (a.order || 99) - (b.order || 99));
---
<Base title="Our Team" description={page.intro}>

  <section class="hero" style="padding-bottom:40px;">
    <div class="container">
      <p class="eyebrow">{page.eyebrow}</p>
      <h1>{page.title}</h1>
      <p class="lead" style="margin-top:20px;">{page.intro}</p>
    </div>
  </section>

  <section class="section tint" style="padding-top:56px;">
    <div class="container">
      <div class="team-grid">
        {members.map((m) => (
          <article class="member reveal">
            <div class="member-head">
              <img src={withBase(m.photo)} alt={m.name} loading="lazy" />
              <div>
                <h3>{m.name}</h3>
                <span class="role">{m.role}</span>
              </div>
            </div>
            <div class="bio">
              <m.Content />
            </div>
            {m.linkedin && <a class="li-link" href={m.linkedin} target="_blank" rel="noopener">LinkedIn →</a>}
          </article>
        ))}
      </div>
    </div>
  </section>

</Base>
