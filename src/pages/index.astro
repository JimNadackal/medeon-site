---
import Base from '../layouts/Base.astro';
import home from '../../content/home.json';
import { withBase } from '../lib/url.js';
---
<Base title="Home" description={home.hero.subtitle}>

  <section class="hero-home">
    <div class="container">
      <div class="hero-card">
        <img src={withBase(home.hero.image)} alt="Enterprise team collaborating" />
        <div class="hero-content">
          <span class="chip">{home.hero.eyebrow}</span>
          <h1>{home.hero.title}</h1>
          <p class="lead">{home.hero.subtitle}</p>
          <div class="hero-ctas">
            <a class="btn light" href={withBase(home.hero.cta_link)}>{home.hero.cta_label}</a>
          </div>
        </div>
      </div>
    </div>
  </section>

  <section class="section">
    <div class="container split">
      <div class="split-sticky reveal">
        <p class="eyebrow">{home.about.eyebrow}</p>
        <h2>{home.about.title}</h2>
        <div style="margin-top:30px;">
          <a class="btn ghost" href={withBase(home.about.cta_link)}>{home.about.cta_label}</a>
        </div>
      </div>
      <div class="prose reveal">
        {home.about.points.map((p) => <p>{p}</p>)}
      </div>
    </div>
  </section>

  <section class="section tint">
    <div class="container">
      <div class="section-head">
        <p class="eyebrow">{home.services.eyebrow}</p>
        <h2>{home.services.title}</h2>
        <p class="lead">{home.services.subtitle}</p>
      </div>
      <div class="cards">
        {home.services.cards.map((card) => (
          <article class="card reveal">
            <img src={withBase(card.image)} alt={card.title} loading="lazy" />
            <div class="card-body">
              <h3>{card.title}</h3>
              <p>{card.text}</p>
            </div>
          </article>
        ))}
      </div>
      <p class="footnote">{home.services.footnote}</p>
      <div style="margin-top:36px;">
        <a class="btn" href={withBase(home.services.cta_link)}>{home.services.cta_label}</a>
      </div>
    </div>
  </section>

  <section class="section">
    <div class="container">
      <div class="panel-dark on-dark">
        <p class="eyebrow">{home.why.eyebrow}</p>
        <h2>{home.why.title}</h2>
        <div class="why-grid">
          {home.why.items.map((item) => (
            <div class="why-item reveal">
              <h3>{item.title}</h3>
              <p>{item.text}</p>
            </div>
          ))}
        </div>
      </div>
    </div>
  </section>

  <section class="cta-band">
    <div class="container">
      <div class="cta-panel">
        <h2>{home.cta.title}</h2>
        <a class="btn" href={withBase(home.cta.button_link)}>{home.cta.button_label}</a>
      </div>
    </div>
  </section>

</Base>
