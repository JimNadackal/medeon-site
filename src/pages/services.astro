---
import Base from '../layouts/Base.astro';
import services from '../../content/services.json';
import { withBase } from '../lib/url.js';
---
<Base title="Services" description={services.intro.text}>

  <section class="hero" style="padding-bottom:56px;">
    <div class="container">
      <p class="eyebrow">{services.intro.eyebrow}</p>
      <h1>{services.intro.title}</h1>
      <p class="lead" style="margin-top:20px;">{services.intro.text}</p>
      <p class="lead" style="margin-top:16px;">{services.intro.text2}</p>
    </div>
  </section>

  <section class="section tint">
    <div class="container split">
      <div class="reveal">
        <p class="eyebrow">{services.consulting.eyebrow}</p>
        <h2>{services.consulting.title}</h2>
        <p style="margin-top:16px;color:var(--slate);">{services.consulting.text}</p>
        <ul class="points">
          {services.consulting.bullets.map((b) => (
            <li><strong style="color:var(--ink);">{b.title}:</strong> {b.text}</li>
          ))}
        </ul>
      </div>
      <div class="reveal">
        <img src={withBase(services.consulting.image)} alt="Consulting and change" loading="lazy" style="border-radius:10px;" />
      </div>
    </div>
  </section>

  <section class="section">
    <div class="container">
      <h2>{services.core.title}</h2>
      <div class="stages">
        {services.core.stages.map((stage, i) => (
          <div class="stage reveal">
            <span class="num">0{i + 1}</span>
            <h3>{stage.title}</h3>
            <ul>
              {stage.bullets.map((b) => <li>{b}</li>)}
            </ul>
          </div>
        ))}
      </div>
    </div>
  </section>

  <section class="section tint">
    <div class="container">
      <h2>{services.products.title}</h2>
      <p class="lead" style="margin-top:16px;">{services.products.text}</p>
      <div class="products">
        {services.products.items.map((item) => (
          <div class="product reveal">
            <h3>{item.title}</h3>
            <p>{item.text}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <section class="section dark on-dark">
    <div class="container">
      <h2>{services.outcomes.title}</h2>
      <p class="lead" style="margin-top:16px;">{services.outcomes.text}</p>
      <ul class="points" style="margin-top:30px;">
        {services.outcomes.bullets.map((b) => <li style="color:#b9c6cf;">{b}</li>)}
      </ul>
    </div>
  </section>

  <section class="section cta-band">
    <div class="container">
      <h2>{services.cta.title}</h2>
      <a class="btn" href={withBase(services.cta.button_link)}>{services.cta.button_label}</a>
    </div>
  </section>

</Base>
