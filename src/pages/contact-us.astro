---
import Base from '../layouts/Base.astro';
import contact from '../../content/contact.json';
---
<Base title="Contact Us" description={contact.subtitle}>

  <section class="hero">
    <div class="container">
      <p class="eyebrow">{contact.eyebrow}</p>
      <h1>{contact.title}</h1>
      <p class="lead" style="margin-top:24px;">{contact.subtitle}</p>
    </div>
  </section>

  <section class="section tint">
    <div class="container">
      <div class="offices">
        {contact.offices.map((o) => (
          <div class="office reveal">
            <h3>{o.city}</h3>
            <p>{o.address}</p>
          </div>
        ))}
      </div>

      <div class="contact-email reveal">
        <div>
          <p class="email-label">Email us</p>
          <a class="email" href={`mailto:${contact.email}`}>{contact.email}</a>
        </div>
        <p>{contact.email_note}</p>
      </div>
    </div>
  </section>

</Base>
